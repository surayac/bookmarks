<!DOCTYPE html>
<html>
  <head>
    <title>BookmarksApi</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
  </head>

  <body>
    <% flash.each do |type, message| %>
      <p><strong><%= type.capitalize %>:</strong> <%= message %></p>
    <% end %>

    <%= yield %>
  </body>
</html>
