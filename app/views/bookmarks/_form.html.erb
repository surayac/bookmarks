<%= form_with model: bookmark do |form| %>
  <% if bookmark.errors.any? %>
    <div>
      <h2><%= pluralize(bookmark.errors.count, "error") %> prevented this bookmark from being saved:</h2>
      <ul>
        <% bookmark.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title %><br>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :url %><br>
    <%= form.url_field :url %>
  </div>

  <div>
    <%= form.label :favorite %>
    <%= form.check_box :favorite %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
