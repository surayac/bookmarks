<h1><%= @bookmark.title %></h1>

<p>
  <strong>URL:</strong>
  <%= link_to @bookmark.url, @bookmark.url, target: "_blank", rel: "noreferrer" %>
</p>

<p>
  <strong>Favorite:</strong>
  <%= @bookmark.favorite ? "Yes" : "No" %>
</p>

<p>
  <%= link_to "Edit", edit_bookmark_path(@bookmark) %> |
  <%= link_to "Back to bookmarks", bookmarks_path %>
</p>
